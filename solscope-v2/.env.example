# ============================================
# SOLSCOPE v2 — Smart Money Intelligence Feed
# ============================================
# Stack: Helius + Jupiter + Nansen
#
# Cost:
#   Helius free tier: 100K DAS calls/mo ($0)
#   Jupiter API: Free
#   Nansen: 10M credits (existing)
#   Hosting: Railway free/$5
#   TOTAL: ~$0-5/month
# ============================================

# HELIUS — Blockchain infrastructure
# Get from: https://dashboard.helius.dev
HELIUS_API_KEY=your_helius_api_key

# NANSEN — Smart money intelligence
# Your existing 10M credits
NANSEN_API_KEY=your_nansen_api_key

# JUPITER — Market data (no key needed for basic, key for higher limits)
# Get from: https://portal.jup.ag (optional)
JUPITER_API_KEY=

# TELEGRAM BOT
# Get from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# SERVER
PORT=3001
NODE_ENV=development

# SIGNAL ENGINE
# How many tokens to actively track
TRACKED_TOKEN_LIMIT=50
# How often to refresh hot tokens (minutes)
HOT_REFRESH_MINUTES=5
# How often to refresh warm tokens (minutes)
WARM_REFRESH_MINUTES=30
# Smart money inflow threshold for conviction alert ($)
CONVICTION_THRESHOLD=1000000
# Holdings change threshold for conviction alert (%)
HOLDINGS_CHANGE_THRESHOLD=15
